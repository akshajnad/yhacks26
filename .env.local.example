# Auth0 (Next.js SDK server env vars)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_auth0_client_id
AUTH0_CLIENT_SECRET=your_auth0_client_secret
AUTH0_SECRET=32_byte_hex_secret
APP_BASE_URL=http://localhost:3000

# SPA callback base URL — must match Auth0 "Allowed Callback URLs" exactly (no trailing slash).
# Set this in production (e.g. https://your-app.vercel.app). Defaults to http://localhost:3000 if unset.
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000

# Optional fallbacks supported by this app for domain/client/origin:
NEXT_PUBLIC_AUTH0_DOMAIN=your-tenant.us.auth0.com
NEXT_PUBLIC_AUTH0_CLIENT_ID=your_auth0_client_id
NEXT_PUBLIC_AUTH0_ORIGIN=http://localhost:3000

# Primary: Lava.so API key (routes requests through Lava → OpenAI gpt-4o)
# Get yours at https://www.lavapayments.com
LAVA_SECRET_KEY=your_lava_secret_key_here

# Fallback: Google AI Studio API key (used if Lava is unavailable)
# Get yours at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here


# Required: Google AI Studio API key
# Get yours at https://aistudio.google.com/apikey
GEMINI_API_KEY=''
# Optional: Override the Gemini model (defaults to gemini-2.0-flash)
# Other options: gemini-1.5-pro, gemini-2.5-pro, etc.
GEMINI_MODEL='gemini-2.5-pro'
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=
AUTH0_CLIENT_ID=""
NEXT_PUBLIC_AUTH0_DOMAIN=
NEXT_PUBLIC_AUTH0_CLIENT_ID=
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
LAVA_FORWARD_TOKEN=''
LAVA_SECRET_KEY=''
ELEVENLABS_AGENT_ID=
ELEVENLABS_AGENT_PHONE_NUMBER_ID=
ELEVENLABS_API_KEY=

# Outbound call — defaults: NO API overrides (first_message / prompt). Use dynamic_variables only.
# In ElevenLabs: set First message = {{opening_script}} and base system prompt = {{system_prompt}}
# Set to true ONLY if your workspace allows API overrides for that field:
ELEVENLABS_ALLOW_FIRST_MESSAGE_OVERRIDE=
ELEVENLABS_ALLOW_PROMPT_OVERRIDE=

# Optional: include empty conversation_config_override { agent: {} } like the raw ElevenLabs curl sample.
# Default is omitted. Set true only if the API errors without it.
ELEVENLABS_INCLUDE_EMPTY_CONVERSATION_OVERRIDE=
GOOGLE_API_KEY=your_google_api_key_here
