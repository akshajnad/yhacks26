# Auth0 (Next.js SDK server env vars)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_auth0_client_id
AUTH0_CLIENT_SECRET=your_auth0_client_secret
AUTH0_SECRET=32_byte_hex_secret
APP_BASE_URL=http://localhost:3000

# SPA callback base URL — must match Auth0 "Allowed Callback URLs" exactly (no trailing slash).
# Set this in production (e.g. https://your-app.vercel.app). Defaults to http://localhost:3000 if unset.
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000

# Optional fallbacks supported by this app for domain/client/origin:
NEXT_PUBLIC_AUTH0_DOMAIN=your-tenant.us.auth0.com
NEXT_PUBLIC_AUTH0_CLIENT_ID=your_auth0_client_id
NEXT_PUBLIC_AUTH0_ORIGIN=http://localhost:3000

# Primary: Lava.so API key (routes requests through Lava → OpenAI gpt-4o)
# Get yours at https://www.lavapayments.com
LAVA_SECRET_KEY=your_lava_secret_key_here

# Fallback: Google AI Studio API key (used if Lava is unavailable)
# Get yours at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here